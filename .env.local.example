# Скопируй в .env.local или выполни:
#   npm run local:setup

SESSION_SECRET=generated-local-secret-replace-with-local-setup
BACKEND_API_URL=http://127.0.0.1:4000
BACKEND_INTERNAL_API_URL=http://127.0.0.1:4000
BACKEND_SESSION_COOKIE_NAME=food_crm_local_api_session
LOCAL_SMOKE_PHONE=+7 900 100-00-09
LOCAL_SMOKE_PASSWORD=generated-local-smoke-password
NEXT_PUBLIC_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CRM_PRODUCTION_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=local

# По умолчанию НЕ задавай NEXT_PUBLIC_BACKEND_API_URL:
# браузер ходит same-origin на /api/v1/*, а Next rewrite проксирует в backend.
# Явный override нужен только для специальных сценариев.
# NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:4000

# Опционально: ссылки в UI (как в .env.production.example)
