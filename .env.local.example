# Скопируй в .env.local и подставь свои значения:
#   cp .env.local.example .env.local

# Обязательно для подписи сессии Next (любая длинная случайная строка).
SESSION_SECRET=local-dev-change-me-to-random-string

# Необязательно: по умолчанию фронт и так ходит на http://127.0.0.1:4000 (см. next.config.ts и shared/api).
# Явно задай, если бэкенд на другом хосте/порту или открываешь CRM не с localhost.
# NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:4000
# BACKEND_API_URL=http://127.0.0.1:4000

