generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum ClientType {
  CLIENT
  ORGANIZATION
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  type      ClientType @default(CLIENT)
  email     String?
  phone     String   @unique
  birthDate DateTime?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String?  @unique
  unit        String
  priceCents  Int
  description String?
  createdAt   DateTime @default(now())
  orderItems  OrderItem[]
}

model Employee {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?  @unique
  role         String
  phone        String?
  messenger    String?
  schedule     Json?    // График работы, например { "monday": 8, "tuesday": 8, ... }
  monthlyHours Int?     // Рассчитанные часы работы за месяц
  birthDate    DateTime?
  hireDate     DateTime?
  createdAt    DateTime @default(now())
  orders       Order[]
  adjustments  EmployeeAdjustment[]
}

enum EmployeeAdjustmentType {
  ADVANCE
  FINE
  DEBT
}

model EmployeeAdjustment {
  id         Int                     @id @default(autoincrement())
  employee   Employee                @relation(fields: [employeeId], references: [id])
  employeeId Int
  type       EmployeeAdjustmentType
  amountCents Int
  comment    String?
  createdAt  DateTime                @default(now())
}

model Order {
  id          Int         @id @default(autoincrement())
  status      OrderStatus @default(PENDING)
  client      Client      @relation(fields: [clientId], references: [id])
  clientId    Int
  employee    Employee    @relation(fields: [employeeId], references: [id])
  employeeId  Int
  totalCents  Int
  createdAt   DateTime    @default(now())
  items       OrderItem[]
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  order           Order   @relation(fields: [orderId], references: [id])
  orderId         Int
  product         Product @relation(fields: [productId], references: [id])
  productId       Int
  quantity        Int
  unitPriceCents  Int
  totalPriceCents Int
}
