# Скопируй содержимое в food-crm-backend/.env (рядом с package.json бэкенда).
# Пароль совпадает с docker-compose.yml в food-crm.

DATABASE_URL="postgresql://food_crm_local:food_crm_local_dev@127.0.0.1:5432/food_crm_local?schema=public"
SESSION_SECRET="local-dev-change-me-use-openssl-rand-hex-32-or-similar"
BACKEND_CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
PORT=4000
